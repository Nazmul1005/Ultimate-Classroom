# ============================================================
# Ultimate Classroom — Environment Variables Template
# ============================================================
# This file is SAFE to commit to Git — it contains NO real keys.
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# --- Google Gemini AI ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server Ports (optional overrides) ---
# PORT_SOCKET=3001
# PORT_PEER=3002

# --- Client URL (used for CORS) ---
# CLIENT_URL=http://localhost:5173
